<UserControl x:Class="wpf_projekt.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Podsumowanie"
                       FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- FILTRY -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Konto"/>
                    <ComboBox Width="160"
                              ItemsSource="{Binding AvailableAccounts}"
                              SelectedItem="{Binding SelectedAccount}"
                              DisplayMemberPath="Name"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Rok"/>
                    <ComboBox Width="100"
                              ItemsSource="{Binding AvailableYears}"
                              SelectedItem="{Binding SelectedYear}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Miesiąc"/>
                    <ComboBox Width="120"
                              ItemsSource="{Binding AvailableMonths}"
                              SelectedItem="{Binding SelectedMonth}"
                              DisplayMemberPath="Label"/>
                </StackPanel>
            </StackPanel>

            <!-- KARTY -->
            <UniformGrid Columns="3">
                <Border Background="#DCFCE7" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Przychody" FontWeight="Bold"/>
                        <TextBlock Text="{Binding IncomeText}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="Green"/>
                    </StackPanel>
                </Border>
                <Border Background="#FEE2E2" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Wydatki" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ExpenseText}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="Red"/>
                    </StackPanel>
                </Border>
                <Border Background="#E0E7FF" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Bilans" FontWeight="Bold"/>
                        <TextBlock Text="{Binding BalanceText}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{Binding BalanceBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

        </StackPanel>
    </Grid>
</UserControl>
