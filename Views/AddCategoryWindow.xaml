<Window x:Class="wpf_projekt.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj nową kategorię" Height="200" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Style="{StaticResource CardStyle}" Margin="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Nazwa nowej kategorii" 
                       Grid.Row="0" Style="{StaticResource FieldLabel}"/>

            <TextBox x:Name="CategoryNameTextBox"
                     Grid.Row="1" VerticalAlignment="Top" Margin="0,5,0,0"
                     Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Anuluj" Style="{StaticResource SecondaryBtn}" 
                        Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                <Button Content="Zapisz" Style="{StaticResource PrimaryBtn}" 
                        IsDefault="True" Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>