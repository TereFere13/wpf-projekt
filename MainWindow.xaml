<Window x:Class="wpf_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:wpf_projekt.Views"
        xmlns:vm="clr-namespace:wpf_projekt.ViewModels"
        Title="Zarządzanie Finansami" Height="600" Width="700"
        Background="#F3F4F6" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <TabControl>

            <!-- DODAJ -->
            <TabItem Header="Dodaj">
                <Border Background="White" Margin="10" Padding="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Dodaj nową transakcję"
                                   FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,20" HorizontalAlignment="Center"/>

                        <TextBlock Text="Kwota (zł):"/>
                        <TextBox x:Name="AmountTextBox"
                                 Margin="0,0,0,10"
                                 Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="AmountTextBox_PreviewTextInput"/>

                        <TextBlock Text="Wybierz konto:"/>
                        <ComboBox Margin="0,0,0,10"
                                  ItemsSource="{Binding Accounts}"
                                  SelectedItem="{Binding SelectedAccount}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Text="Data transakcji:"/>
                        <DatePicker Margin="0,0,0,10"
                                    SelectedDate="{Binding TransactionDate}"/>

                        <TextBlock Text="Opis:"/>
                        <TextBox Margin="0,0,0,10"
                                 Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Kategoria:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="Name"
                                      Width="200"/>
                            <Button Content="+" Width="30" Margin="10,0,0,0"
                                    ToolTip="Dodaj własną kategorię" Cursor="Hand"
                                    Command="{Binding OpenAddCategoryCommand}"/>
                        </StackPanel>

                        <TextBlock Text="Typ transakcji:"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton Content="Wydatek"
                                         IsChecked="{Binding IsExpense}"
                                         Margin="0,0,20,0"/>
                            <RadioButton Content="Przychód"
                                         IsChecked="{Binding IsIncome}"/>
                        </StackPanel>

                        <Button Content="Dodaj transakcję"
                                Command="{Binding SaveTransactionCommand}"
                                Padding="10"
                                Background="#0078D7"
                                Foreground="White"
                                FontWeight="Bold"/>

                        <!-- Transfer -->
                        <TextBlock Text="Transfer między kontami"
                                   FontWeight="Bold" Margin="0,16,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding TransferFrom}"
                                      DisplayMemberPath="DisplayName"
                                      Width="200" Margin="0,0,10,0"/>
                            <ComboBox ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding TransferTo}"
                                      DisplayMemberPath="DisplayName"
                                      Width="200" Margin="0,0,10,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="100" Margin="0,0,10,0"
                                     ToolTip="Kwota transferu"
                                     Text="{Binding TransferAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Width="240" Margin="0,0,10,0"
                                     ToolTip="Opis transferu"
                                     Text="{Binding TransferDescription, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Wykonaj transfer" Width="120"
                                    Command="{Binding ExecuteTransferCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- KONTA -->
            <TabItem Header="Konta">
                <Border Background="White" Margin="10" Padding="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Zarządzanie kontami"
                                   FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,20" HorizontalAlignment="Center"/>

                        <TextBlock Text="Dodaj nowe konto" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox Width="220" Margin="0,0,10,0"
                                     ToolTip="Nazwa nowego konta"
                                     Text="{Binding NewAccountName, UpdateSourceTrigger=PropertyChanged}"/>
                            <ComboBox Width="120" Margin="0,0,10,0"
                                      SelectedValue="{Binding NewAccountType}">
                                <ComboBoxItem Content="Osobiste" IsSelected="True"/>
                                <ComboBoxItem Content="Wspólne"/>
                            </ComboBox>
                            <Button Content="Dodaj konto" Width="110"
                                    Command="{Binding AddAccountCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- TRANSAKCJE -->
            <TabItem Header="Transakcje">
                <views:TransactionsView DataContext="{Binding TransactionsVm}"/>
            </TabItem>

            <!-- PODSUMOWANIE -->
            <TabItem Header="Podsumowanie">
                <views:SummaryView DataContext="{Binding SummaryVm}"/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
